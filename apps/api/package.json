    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.6.0",
    "@scene-report/shared": "0.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.1",
    "jose": "^5.9.6",
    "openai": "^4.91.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
